---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
const { pageTitle } = Astro.props;
---

<BaseLayout pageTitle="Een Website Laten Maken | Kristof De Moor">
	<!-- Header -->
	<header class="max-w-7xl mx-auto px-5">
		<div
			class="flex flex-col justify-center items-center text-center px-5 space-y-8 max-w-2xl mx-auto min-h-screen">
			<h1 class="text-4xl font-bold md:text-5xl">
				Een website laten maken op maat van uw bedrijf<span class="text-rose">.</span>
			</h1>
			<p class="md:text-lg">
				Ik maak moderne websites op maat van jouw bedrijf en verwachtingen. Van strategie en design tot
				ontwikkeling en lancering.
			</p>
			<!-- Buttons -->
			<div class="mt-2">
				<a href="#projects" class="bg-cyan text-background rounded-4xl px-6 py-3 me-3 hover:bg-rose"
					>Vraag offerte aan</a
				>
			</div>
		</div>
	</header>
	<!-- Wat mag je verwachten -->
	<section id="verwachtingen" class="max-w-7xl mx-auto px-5">
		<h2 class="text-3xl font-bold text-center md:text-4xl">
			Wat je mag verwachten<span class="text-rose">.</span>
		</h2>
		<!-- Cards container -->
		<div class="flex flex-wrap gap-15 space-y-5 justify-center items-center my-25 max-w-6xl mx-auto">
			<!-- Card 1: Design op maat -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-6 left-32">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="80">
						<path
							fill="rgb(255 32 86)"
							d="M512.5 74.3L291.1 222C262 241.4 243.5 272.9 240.5 307.3C302.8 320.1 351.9 369.2 364.8 431.6C399.3 428.6 430.7 410.1 450.1 381L597.7 159.5C604.4 149.4 608 137.6 608 125.4C608 91.5 580.5 64 546.6 64C534.5 64 522.6 67.6 512.5 74.3zM320 464C320 402.1 269.9 352 208 352C146.1 352 96 402.1 96 464C96 467.9 96.2 471.8 96.6 475.6C98.4 493.1 86.4 512 68.8 512L64 512C46.3 512 32 526.3 32 544C32 561.7 46.3 576 64 576L208 576C269.9 576 320 525.9 320 464z"
						></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold mt-18">Design op maat</h3>
				<p class="font-light leading-relaxed mt-4">
					Elke website wordt op maat ontworpen en afgestemd op jouw bedrijf. Zo krijg je een unieke website
					die zorgt voor een professionele uitstraling van jouw merk.
				</p>
			</div>
			<!-- Card 2: Focus op resultaat -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-9 left-28">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="95"
						><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
						<path
							fill="rgb(255 32 86)"
							d="M416 224C398.3 224 384 209.7 384 192C384 174.3 398.3 160 416 160L576 160C593.7 160 608 174.3 608 192L608 352C608 369.7 593.7 384 576 384C558.3 384 544 369.7 544 352L544 269.3L374.6 438.7C362.1 451.2 341.8 451.2 329.3 438.7L224 333.3L86.6 470.6C74.1 483.1 53.8 483.1 41.3 470.6C28.8 458.1 28.8 437.8 41.3 425.3L201.3 265.3C213.8 252.8 234.1 252.8 246.6 265.3L352 370.7L498.7 224L416 224z"
						></path></svg
					>
				</div>
				<h3 class="text-xl font-bold mt-18">Focus op resultaat</h3>
				<p class="font-light leading-relaxed mt-4">
					Een sterke website draagt bij aan de groei van je bedrijf. De focus ligt op meer zichtbaarheid voor
					je bedrijf, meer aanvragen, meer klanten en meer vertrouwen.
				</p>
			</div>
			<!-- Card 3: Persoonlijk contact -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-6 left-32">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="70"
						><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
						<path
							fill="rgb(255 32 86)"
							d="M300.9 117.2L184.3 246.8C179.7 251.9 179.9 259.8 184.8 264.7C215.3 295.2 264.8 295.2 295.3 264.7L327.1 232.9C331.3 228.7 336.6 226.4 342 226C348.8 225.4 355.8 227.7 361 232.9L537.6 408L608 352L608 64L496 128L472.2 112.1C456.4 101.6 437.9 96 418.9 96L348.5 96C347.4 96 346.2 96 345.1 96.1C328.2 97 312.3 104.6 300.9 117.2zM148.6 214.7L255.4 96L215.8 96C190.3 96 165.9 106.1 147.9 124.1L32 256L32 608L176 472L188.4 482.3C211.4 501.5 240.4 512 270.3 512L286 512L279 505C269.6 495.6 269.6 480.4 279 471.1C288.4 461.8 303.6 461.7 312.9 471.1L353.9 512.1L362.9 512.1C382 512.1 400.7 507.8 417.7 499.8L391 473C381.6 463.6 381.6 448.4 391 439.1C400.4 429.8 415.6 429.7 424.9 439.1L456.9 471.1L474.4 453.6C483.3 444.7 485.9 431.8 482 420.5L344.1 283.7L329.2 298.6C279.9 347.9 200.1 347.9 150.8 298.6C127.8 275.6 126.9 238.7 148.6 214.6z"
						></path></svg
					>
				</div>
				<h3 class="text-xl font-bold mt-18">Persoonlijk contact</h3>
				<p class="font-light leading-relaxed mt-4">
					Kleine zaak, grote aandacht. Tijdens het volledige project ben ik jouw aanspreekpunt. Dat zorgt voor
					duidelijke communicatie en snelle opvolging.
				</p>
			</div>
			<!-- Card 4: Snell oplevering -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-6 left-32">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="72"
						><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
						<path
							fill="rgb(255 32 86)"
							d="M64 160C64 124.7 92.7 96 128 96L416 96C451.3 96 480 124.7 480 160L480 192L530.7 192C547.7 192 564 198.7 576 210.7L621.3 256C633.3 268 640 284.3 640 301.3L640 448C640 483.3 611.3 512 576 512L572.7 512C562.3 548.9 528.3 576 488 576C447.7 576 413.8 548.9 403.3 512L300.7 512C290.3 548.9 256.3 576 216 576C175.7 576 141.8 548.9 131.3 512L128 512C92.7 512 64 483.3 64 448L64 400L24 400C10.7 400 0 389.3 0 376C0 362.7 10.7 352 24 352L136 352C149.3 352 160 341.3 160 328C160 314.7 149.3 304 136 304L24 304C10.7 304 0 293.3 0 280C0 266.7 10.7 256 24 256L200 256C213.3 256 224 245.3 224 232C224 218.7 213.3 208 200 208L24 208C10.7 208 0 197.3 0 184C0 170.7 10.7 160 24 160L64 160zM576 352L576 301.3L530.7 256L480 256L480 352L576 352zM256 488C256 465.9 238.1 448 216 448C193.9 448 176 465.9 176 488C176 510.1 193.9 528 216 528C238.1 528 256 510.1 256 488zM488 528C510.1 528 528 510.1 528 488C528 465.9 510.1 448 488 448C465.9 448 448 465.9 448 488C448 510.1 465.9 528 488 528z"
						></path></svg
					>
				</div>
				<h3 class="text-xl font-bold mt-18">Snelle oplevering</h3>
				<p class="font-light leading-relaxed mt-4">
					Dankij een duidelijke en realistische planning kan jouw website snel en efficiënt opgeleverd worden
					zonder verrassingen.
				</p>
			</div>
			<!-- Card 5: Ondersteuning -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-6 left-32">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="75">
						<path
							fill="rgb(255 32 86)"
							d="M320 128C241 128 175.3 185.3 162.3 260.7C171.6 257.7 181.6 256 192 256L208 256C234.5 256 256 277.5 256 304L256 400C256 426.5 234.5 448 208 448L192 448C139 448 96 405 96 352L96 288C96 164.3 196.3 64 320 64C443.7 64 544 164.3 544 288L544 456.1C544 522.4 490.2 576.1 423.9 576.1L336 576L304 576C277.5 576 256 554.5 256 528C256 501.5 277.5 480 304 480L336 480C362.5 480 384 501.5 384 528L384 528L424 528C463.8 528 496 495.8 496 456L496 435.1C481.9 443.3 465.5 447.9 448 447.9L432 447.9C405.5 447.9 384 426.4 384 399.9L384 303.9C384 277.4 405.5 255.9 432 255.9L448 255.9C458.4 255.9 468.3 257.5 477.7 260.6C464.7 185.3 399.1 127.9 320 127.9z"
						></path></svg
					>
				</div>
				<h3 class="text-xl font-bold mt-18">Ondersteuning</h3>
				<p class="font-light leading-relaxed mt-4">
					Tijdens het volledige project van start tot lancering kan je op mij rekenen. Ook na oplevering sta
					ik voor jou klaar voor vragen of advies.
				</p>
			</div>
			<!-- Card 6: Scherpe prijzen -->
			<div class="relative bg-white/10 rounded-3xl px-8 pb-8 w-xs">
				<div class="absolute -top-6 left-32">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="80">
						<path
							fill="rgb(255 32 86)"
							d="M144 224C161.7 224 176 238.3 176 256L176 512C176 529.7 161.7 544 144 544L96 544C78.3 544 64 529.7 64 512L64 256C64 238.3 78.3 224 96 224L144 224zM334.6 80C361.9 80 384 102.1 384 129.4L384 133.6C384 140.4 382.7 147.2 380.2 153.5L352 224L512 224C538.5 224 560 245.5 560 272C560 291.7 548.1 308.6 531.1 316C548.1 323.4 560 340.3 560 360C560 383.4 543.2 402.9 521 407.1C525.4 414.4 528 422.9 528 432C528 454.2 513 472.8 492.6 478.3C494.8 483.8 496 489.8 496 496C496 522.5 474.5 544 448 544L360.1 544C323.8 544 288.5 531.6 260.2 508.9L248 499.2C232.8 487.1 224 468.7 224 449.2L224 262.6C224 247.7 227.5 233 234.1 219.7L290.3 107.3C298.7 90.6 315.8 80 334.6 80z"
						></path></svg
					>
				</div>
				<h3 class="text-xl font-bold mt-18">Scherpe prijzen</h3>
				<p class="font-light leading-relaxed mt-4">
					Voor elk project maak ik een duidelijke offerte met scherpe prijzen zodat je exact weet wat de
					kosten zijn voor we van start gaan.
				</p>
			</div>
		</div>
	</section>
	<!-- Hoe het proces verloopt -->
	<section id="process" class="max-w-7xl mx-auto px-5 my-35">
		<h2 class="text-3xl font-bold text-center md:text-4xl">
			Hoe het proces verloopt<span class="text-rose">.</span>
		</h2>
		<!-- Proces container -->
		<div class="flex flex-wrap gap-12 justify-center my-20 mx-auto">
			<!-- Step 1 -->
			<div class="flex flex-col space-y-8 justify-center items-center w-60 mb-5">
				<!-- Circle -->
				<div
					class="flex items-center justify-center text-4xl font-extrabold text-rose bg-white/10 rounded-full w-18 h-18 p-2">
					1
				</div>
                <!-- Text -->
                 <h3 class="text-xl font-bold text-rose ">Kennismaking</h3>
                 <p class="font-light text-center leading-relaxed">We starten met een gesprek waarin we jouw bedrijf,  en doelstellingen bespreken. Ik luister naar jouw ideeën en verwachtingen, zodat we een duidelijk beeld krijgen van wat jouw website moet bereiken.</p>
			</div>
			<!-- Step 2 -->
			<div class="flex flex-col space-y-8 justify-center items-center w-60 mb-5">
				<!-- Circle -->
				<div
					class="flex items-center justify-center text-4xl font-extrabold text-rose bg-white/10 rounded-full w-18 h-18 p-2">
					2
				</div>
                <!-- Text -->
                 <h3 class="text-xl font-bold text-rose ">Design</h3>
                 <p class="font-light text-center leading-relaxed">Op basis van ons gesprek werk ik een projectplan en visueel ontwerp van de website uit. Jij geeft feedback en ik pas aan waar nodig. We gaan verder naar de volgende stap zodra jij tevreden bent.</p>
			</div>
			<!-- Step 3 -->
			<div class="flex flex-col space-y-8 justify-center items-center w-60 mb-5">
				<!-- Circle -->
				<div
					class="flex items-center justify-center text-4xl font-extrabold text-rose bg-white/10 rounded-full w-18 h-18 p-2">
					3
				</div>
                <!-- Text -->
                 <h3 class="text-xl font-bold text-rose ">Ontwikkeling</h3>
                 <p class="font-light text-center leading-relaxed">Op basis van ons gesprek werk ik een projectplan en visueel ontwerp van de website uit. Jij geeft feedback en ik pas aan waar nodig. We gaan verder naar de volgende stap zodra jij tevreden bent.</p>
			</div>
                <!-- Step 4 -->
                <div class="flex flex-col space-y-8 justify-center items-center w-60">
                    <!-- Circle -->
                    <div
                        class="flex items-center justify-center text-4xl font-extrabold text-rose bg-white/10 rounded-full w-18 h-18 p-2">
                        4
                    </div>
                    <!-- Text -->
                    <h3 class="text-xl font-bold text-rose ">Lancering</h3>
                    <p class="font-light text-center leading-relaxed">Op basis van ons gesprek werk ik een projectplan en visueel ontwerp van de website uit. Jij geeft feedback en ik pas aan waar nodig. We gaan verder naar de volgende stap zodra jij tevreden bent.</p>
                </div>
		</div>
	</section>
</BaseLayout>
