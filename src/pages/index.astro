---
import "../styles/global.css";
import logo from "../assets/kristof-logo-white.webp";
import heroImage from "../assets/hero-kristof.webp";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<!-- Radial Gradient Light Effect -->
		<div class="inset-0 -z-10 overflow-hidden">
			<div
				class="absolute -top-250 left-1/2 transform -translate-x-1/2 -translate-y-50 w-1/2 h-full bg-cyan/10 rounded-full blur-3xl">
			</div>
		</div>

		<!-- Navigation -->
		<!-- <nav class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-sm"> -->
		<nav class="fixed top-0 w-full z-50 backdrop-blur-sm">
			<div class="mx-auto max-w-7xl">
				<div class="flex h-18 items-center justify-between">
					<!-- Logo -->
					<div class="ps-5">
						<a href="#">
							<img src={logo.src} alt="Logo Kristof" class="h-7 w-auto" />
						</a>
					</div>

					<!-- Mobile menu button-->
					<div class="pe-4 sm:hidden">
						<button
							type="button"
							id="mobile-menu-button"
							class="relative inline-flex items-center justify-center rounded-md p-2 text-rose hover:bg-white/5 hover:text-white focus:outline-2 focus:-outline-offset-1 focus:outline-rose">
							<span class="absolute -inset-0.5"></span>
							<span class="sr-only">Open main menu</span>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								data-slot="icon"
								aria-hidden="true"
								class="size-8 hamburger-icon">
								<path
									d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								data-slot="icon"
								aria-hidden="true"
								class="size-8 close-icon hidden">
								<path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
							</svg>
						</button>
					</div>

					<!-- Nav Items -->
					<div class="hidden sm:flex flex-1 items-center sm:items-stretch sm:justify-end">
						<div class="flex justify-end space-x-4 pe-5">
							<a href="#about" class="px-3 py-2 sm:text-sm text-white hover:text-rose">Over Mij</a>
							<a href="#services" class="px-3 py-2 sm:text-sm text-white hover:text-rose">Diensten</a>
							<a href="#projects" class="px-3 py-2 sm:text-sm text-white hover:text-rose">Projecten</a>
							<a
								href="#contact"
								class="bg-rose rounded-4xl px-5 py-2 sm:text-sm ms-5 text-background hover:bg-cyan"
								>Contact</a
							>
						</div>
					</div>
				</div>
			</div>

			<div
				id="mobile-menu"
				class="hidden block sm:hidden overflow-hidden transition-all duration-500 ease-in-out max-h-0">
				<div class="space-y-1 px-4 pt-4 pb-3 border-b border-gray-700">
					<a
						href="#about"
						class="block rounded-md px-6 py-2 text-base font-medium text-gray-300 hover:bg-white/5 hover:text-rose"
						>Over Mij</a
					>
					<a
						href="#services"
						class="block rounded-md px-6 py-2 text-base font-medium text-gray-300 hover:bg-white/5 hover:text-rose"
						>Diensten</a
					>
					<a
						href="#projects"
						class="block rounded-md px-6 py-2 text-base font-medium text-gray-300 hover:bg-white/5 hover:text-rose"
						>Projecten</a
					>

					<div class="mt-10 ms-4 mb-25">
						<a href="#contact" class="bg-rose rounded-4xl px-5 py-2 text-sm text-background hover:bg-cyan"
							>Contact</a
						>
					</div>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<header class="mx-auto max-w-7xl pt-20 px-4 mb-20 sm:px-6 lg:px-8">
			<div class="flex flex-col-reverse justify-center md:flex-row sm:items-center">
				<div class="mx-auto text-center md:ms-10 space-y-6 max-w-lg md:text-left">
					<h1 class="font-bold text-4xl leading-snug pt-6 sm:text-5xl xl:text-6xl xl:leading-18">
						Hallo, mijn<br />naam is Kristof
					</h1>
					<h2 class="font-extralight text-2xl sm:text-4xl mt-4">
						Ik ben een <span class="text-cyan">developer</span>
					</h2>
					<p class="font-light lg:text-lg text-white/70 leading-loose lg:pe-5">
						Met sterke websites en krachtige visuele beelden help ik jouw bedrijf groeien in de digitale
						wereld.
					</p>
					<div class="mt-10">
						<a href="#projects" class="bg-cyan text-background rounded-4xl px-6 py-3 me-3 hover:bg-rose"
							>Projecten</a
						>
						<a
							href="#contact"
							class="bg-cyan/10 text-white/70 border border-white/20 rounded-4xl px-7 py-3 hover:bg-rose hover:text-background"
							>Contact</a
						>
					</div>
				</div>
				<div class="flex justify-center">
					<img src={heroImage.src} alt="Hero Image" class="h-auto w-full min-w-xs max-w-sm lg:max-w-xl" />
				</div>
			</div>
		</header>

		<!-- Highlights -->
		<section class="py-10">
			<div class="mx-auto max-w-6xl px-6 lg:px-8">
				<div
					class="flex flex-col gap-4 rounded-4xl bg-white/5 p-5 shadow-xl shadow-black/10 sm:flex-row sm:justify-between sm:p-6">
					<div class="flex-1 rounded-3xl bg-white/5 p-5 text-center backdrop-blur-sm sm:p-6">
						<div
							class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-rose/10 text-rose">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="34"
								height="34"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="icon icon-tabler icons-tabler-filled icon-tabler-clock">
								<path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
								<path
									d="M17 3.34a10 10 0 1 1 -14.995 8.984l-.005 -.324l.005 -.324a10 10 0 0 1 14.995 -8.336zm-5 2.66a1 1 0 0 0 -.993 .883l-.007 .117v5l.009 .131a1 1 0 0 0 .197 .477l.087 .1l3 3l.094 .082a1 1 0 0 0 1.226 0l.094 -.083l.083 -.094a1 1 0 0 0 0 -1.226l-.083 -.094l-2.707 -2.708v-4.585l-.007 -.117a1 1 0 0 0 -.993 -.883z"
								></path>
							</svg>
						</div>
						<p class="text-5xl font-semibold text-white counter" data-target="15">0</p>
						<p class="mt-2 text-sm text-white/70">jaar ervaring</p>
					</div>
					<div class="flex-1 rounded-3xl bg-white/5 p-5 text-center backdrop-blur-sm sm:p-6">
						<div
							class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-rose/10 text-rose">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="size-7">
								<path
									d="M4.5 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM14.25 8.625a3.375 3.375 0 1 1 6.75 0 3.375 3.375 0 0 1-6.75 0ZM1.5 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM17.25 19.128l-.001.144a2.25 2.25 0 0 1-.233.96 10.088 10.088 0 0 0 5.06-1.01.75.75 0 0 0 .42-.643 4.875 4.875 0 0 0-6.957-4.611 8.586 8.586 0 0 1 1.71 5.157v.003Z"
								></path>
							</svg>
						</div>
						<p class="text-5xl font-semibold text-white counter" data-target="50">0</p>
						<p class="mt-2 text-sm text-white/70">klanten</p>
					</div>
					<div class="flex-1 rounded-3xl bg-white/5 p-5 text-center backdrop-blur-sm sm:p-6">
						<div
							class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-rose/10 text-rose">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="34"
								height="34"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="icon icon-tabler icons-tabler-filled icon-tabler-briefcase">
								<path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
								<path
									d="M22 13.478v4.522a3 3 0 0 1 -3 3h-14a3 3 0 0 1 -3 -3v-4.522l.553 .277a20.999 20.999 0 0 0 18.897 -.002l.55 -.275zm-8 -11.478a3 3 0 0 1 3 3v1h2a3 3 0 0 1 3 3v2.242l-1.447 .724a19.002 19.002 0 0 1 -16.726 .186l-.647 -.32l-1.18 -.59v-2.242a3 3 0 0 1 3 -3h2v-1a3 3 0 0 1 3 -3h4zm-2 8a1 1 0 0 0 -1 1a1 1 0 1 0 2 .01c0 -.562 -.448 -1.01 -1 -1.01zm2 -6h-4a1 1 0 0 0 -1 1v1h6v-1a1 1 0 0 0 -1 -1z"
								></path>
							</svg>
						</div>
						<p class="text-5xl font-semibold text-white counter" data-target="100">0</p>
						<p class="mt-2 text-sm text-white/70">projecten</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Main -->
		<main>
			<!-- "Over Mij" -->
			<section id="about" class="py-25">
				<div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
					<h2
						class="text-3xl font-extrabold text-white mb-8 flex items-center justify-center gap-2 sm:text-4xl">
						Over mij<span class="relative text-rose -left-1">.</span>
					</h2>
					<p class="text-white/70 leading-relaxed max-w-3xl mx-auto sm:text-lg">
						Als freelance webdeveloper, designer en fotograaf laat ik merken groeien. Met meer dan 15 jaar
						ervaring met het bouwen van websites, grafisch ontwerp en fotografie help ik KMO's om zich te
						onderscheiden met een sterke visuele identiteit.<br /><br />
						Van het ontwerpen van een logo tot het bouwen van een complete website, van fotografie tot het creëren
						van creatief drukwerk — ik bied een totaalpakket aan creatieve digitale diensten, afgestemd op jouw
						unieke verhaal en doelgroep.
					</p>
				</div>
			</section>

			<!-- "Diensten" -->
			<section id="services" class="py-25">
				<div class="max-w-7xl mx-auto px-6 lg:px-8">
					<h2
						class="text-3xl font-extrabold text-white mb-20 text-center flex items-center justify-center gap-2 sm:text-4xl">
						Diensten<span class="relative text-rose -left-1">.</span>
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 md:px-25 gap-15">
						<div
							class="relative rounded-3xl bg-white/5 p-8 text-center backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl hover:bg-white/10 transition-all duration-300 cursor-pointer">
							<a href="website.html" class="block h-full">
								<img
									src="/src/assets/rocket.png"
									alt="website rocket icon"
									class="mx-auto h-12 w-12 -mt-14 mb-6 transition-all duration-300"
								/>
								<h3
									class="text-xl font-semibold text-white border-b border-rose max-w-[50%] mx-auto pb-3 mb-6">
									Websites
								</h3>
								<p class="font-light text-slate-400 leading-relaxed">
									Wil je een website laten maken die er niet alleen goed uitziet, maar ook resultaat
									oplevert? Van concept tot lancering, ik ontwerp en ontwikkel websites op maat die
									jouw bedrijf laten groeien.
								</p>
							</a>
						</div>
						<div
							class="relative rounded-3xl bg-white/5 p-8 text-center backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl hover:bg-white/10 transition-all duration-300 cursor-pointer">
							<a href="grafisch-ontwerp.html" class="block h-full">
								<img
									src="/src/assets/pencils.png"
									alt="grafisch ontwerp icon"
									class="mx-auto h-14 w-14 -mt-14 mb-6 transition-all duration-300"
								/>
								<h3
									class="text-xl font-semibold text-white border-b border-rose max-w-[50%] mx-auto pb-3 mb-6">
									Design
								</h3>
								<p class="font-light text-slate-400 leading-relaxed">
									Ik help je om een sterke visuele identiteit uit te bouwen die perfect aansluit bij
									jouw merk en bedrijf. Van een uniek logo tot een consistente huisstijl en
									professioneel drukwerk.
								</p>
							</a>
						</div>
						<div
							class="relative rounded-3xl bg-white/5 p-8 text-center backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl hover:bg-white/10 transition-all duration-300 cursor-pointer">
							<a href="fotografie.html" class="block h-full">
								<img
									src="/src/assets/photo.png"
									alt="fotografie icon"
									class="mx-auto h-14 w-14 -mt-14 mb-6 transition-all duration-300"
								/>
								<h3
									class="text-xl font-semibold text-white border-b border-rose max-w-[50%] mx-auto pb-3 mb-6">
									Fotografie
								</h3>
								<p class="font-light text-slate-400 leading-relaxed">
									Professionele fotografie nodig voor jouw bedrijf? Met sterke productfotografie,
									portretfotografie of eventfotografie geef ik jouw bedrijf een professionele
									uitstraling.
								</p>
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- "Projecten" -->
			<section id="projects" class="py-25">
				<div class="max-w-7xl mx-auto px-6 lg:px-8">
					<h2
						class="text-3xl font-extrabold text-white mb-10 text-center flex items-center justify-center gap-2 sm:text-4xl">
						Projecten<span class="relative text-rose -left-1">.</span>
					</h2>
					<div class="mb-15 flex flex-wrap justify-center gap-3">
						<button
							type="button"
							data-filter=".all"
							class="filter-btn rounded-full px-5 py-2 text-sm font-medium bg-rose text-white shadow-sm shadow-rose/20"
							>Alles</button
						>
						<button
							type="button"
							data-filter=".website"
							class="filter-btn rounded-full px-5 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10"
							>Website</button
						>
						<button
							type="button"
							data-filter=".grafisch-ontwerp"
							class="filter-btn rounded-full px-5 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10"
							>Grafisch Ontwerp</button
						>
						<button
							type="button"
							data-filter=".fotografie"
							class="filter-btn rounded-full px-5 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10"
							>Fotografie</button
						>
					</div>
					<div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						<!-- Project 1: Website -->
						<div
							data-category="website"
							class="website group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-cyan/20 to-rose/20 flex items-center justify-center">
								<!-- <img src="/src/assets/project-harvard.png" alt="Project Harvard" class="h-full w-full object-cover transition-all duration-300 group-hover:scale-110"> -->
								<img
									src="/src/assets/project-harvard.png"
									alt="Project Harvard"
									class="h-full w-full object-cover transition-all duration-300 group-hover:scale-110"
								/>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">Website</div>
								<h3 class="text-xl font-semibold text-white mb-2">Harvard CS50 Final Project</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Een HTML5 Star Wars Space Shooter gebouwd met Phaser game framework als final
									project voor Harvard's CS50 Computer Science course.
								</p>
							</div>
						</div>
						<!-- Project 2: Grafisch Ontwerp -->
						<div
							data-category="grafisch-ontwerp"
							class="grafisch-ontwerp group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-rose/20 to-cyan/20 flex items-center justify-center">
								<span class="text-white/50 text-sm">Design Preview</span>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">
									Grafisch Ontwerp
								</div>
								<h3 class="text-xl font-semibold text-white mb-2">Logo Ontwerp voor Tech Startup</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Creatief logo en branding pakket voor een innovatieve tech startup, inclusief
									visitekaartjes en social media templates.
								</p>
							</div>
						</div>
						<!-- Project 3: Fotografie -->
						<div
							data-category="fotografie"
							class="fotografie group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-cyan/20 to-rose/20 flex items-center justify-center">
								<span class="text-white/50 text-sm">Foto Preview</span>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">
									Fotografie
								</div>
								<h3 class="text-xl font-semibold text-white mb-2">
									Product Fotografie voor Fashion Brand
								</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Professionele productfoto's voor een mode merk, met aandacht voor styling,
									belichting en compositie.
								</p>
							</div>
						</div>
						<!-- Project 4: Website -->
						<div
							data-category="website"
							class="website group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-rose/20 to-cyan/20 flex items-center justify-center">
								<span class="text-white/50 text-sm">Website Preview</span>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">Website</div>
								<h3 class="text-xl font-semibold text-white mb-2">Portfolio Site voor Fotograaf</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Een elegante portfolio website met galerij, contactformulier en blog integratie voor
									een professionele fotograaf.
								</p>
							</div>
						</div>
						<!-- Project 5: Grafisch Ontwerp -->
						<div
							data-category="grafisch-ontwerp"
							class="grafisch-ontwerp group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-cyan/20 to-rose/20 flex items-center justify-center">
								<span class="text-white/50 text-sm">Design Preview</span>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">
									Grafisch Ontwerp
								</div>
								<h3 class="text-xl font-semibold text-white mb-2">Brochure Ontwerp voor Restaurant</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Visueel aantrekkelijke brochure voor een restaurant, inclusief menu design en
									fotografie styling.
								</p>
							</div>
						</div>
						<!-- Project 6: Fotografie -->
						<div
							data-category="website"
							class="website group rounded-3xl bg-white/5 overflow-hidden backdrop-blur-sm border border-white/10 hover:scale-105 hover:shadow-2xl transition-all duration-300 cursor-pointer">
							<div
								class="aspect-video bg-linear-to-br from-rose/20 to-cyan/20 flex items-center justify-center">
								<span class="text-white/50 text-sm">Foto Preview</span>
							</div>
							<div class="p-6">
								<div class="text-xs uppercase tracking-wide text-rose font-semibold mb-2">
									Fotografie
								</div>
								<h3 class="text-xl font-semibold text-white mb-2">
									Evenement Fotografie voor Bedrijfsfeest
								</h3>
								<p class="text-white/70 text-sm leading-relaxed">
									Uitgebreide fotoreportage van een bedrijfsfeest, met aandacht voor sfeer, mensen en
									details.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- "Contact" -->
			<section id="contact" class="pt-25 bg-linear-to-b from-background to-slate-900">
				<div class="max-w-6xl mx-auto px-6 lg:px-8">
					<h2
						class="text-3xl font-extrabold text-white mb-15 text-center flex items-center justify-center gap-2 sm:text-4xl">
						Contact<span class="relative text-rose -left-1">.</span>
					</h2>
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-35">
						<!-- Contact Info -->
						<div class="space-y-15">
							<div>
